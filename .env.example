# --- Database (Supabase Postgres + pgvector) ---
# Use the Supabase "Connection string" (Transaction pooler for serverless / Vercel).
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres"

# --- OpenAI ---
OPENAI_API_KEY="sk-..."
# Model ids live in env (availability/pricing shifts) -- never hardcode in source or README.
OPENAI_REASONING_MODEL="gpt-5.5"
OPENAI_FAST_MODEL="gpt-5.4-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# --- Retrieval / grounding ---
# Cosine SIMILARITY in [0,1]. Below this, /api/ask refuses ("not found in your materials").
RETRIEVAL_MIN_SCORE="0.25"
RETRIEVAL_TOP_K="6"

# --- Spend protection (public demo) ---
RATE_LIMIT_PER_MIN="5"      # max requests per IP per minute
DAILY_REQUEST_CAP="60"      # global max model-backed requests per day
